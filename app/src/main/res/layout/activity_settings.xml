<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/screen_background"
    tools:context=".activity_settings">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp" />

        <!-- SECTION 1: Regional & Localization -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Localization"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#1976D2"
            android:textAllCaps="true"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Primary Billing Currency"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorPrimary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Set the symbol used on generated invoice forms."
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="12dp" />

            <!-- Currency Selection Exposed Dropdown -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilCurrency"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp">

                <AutoCompleteTextView
                    android:id="@+id/actvCurrency"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:textColor="?android:attr/textColorPrimary" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- SECTION 2: Display Themes -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Appearance"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#1976D2"
            android:textAllCaps="true"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="App Theme"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorPrimary"
                android:layout_marginBottom="12dp" />

            <!-- Theme Options Radio Group -->
            <RadioGroup
                android:id="@+id/rgTheme"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbThemeSystem"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="System Default"
                    android:textSize="14sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/rbThemeLight"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="Light Mode"
                    android:textSize="14sp"
                    android:textColor="?android:attr/textColorPrimary" />

                <RadioButton
                    android:id="@+id/rbThemeDark"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="Dark Mode"
                    android:textSize="14sp"
                    android:textColor="?android:attr/textColorPrimary" />
            </RadioGroup>
        </LinearLayout>

        <!-- SECTION 3: General Actions -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Account &amp; Security"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#1976D2"
            android:textAllCaps="true"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="4dp"
            android:layout_marginBottom="24dp">

            <!-- Edit Profile Action Row -->
            <LinearLayout
                android:id="@+id/llEditProfile"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Edit Business Profile"
                    android:textSize="15sp"
                    android:textColor="?android:attr/textColorPrimary"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="22sp"
                    android:textColor="?android:attr/textColorSecondary"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorOutline"
                android:layout_marginHorizontal="12dp"/>

            <!-- Logout Action Row -->
            <LinearLayout
                android:id="@+id/llLogout"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Sign Out"
                    android:textSize="15sp"
                    android:textColor="#C62828"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Save Button -->
        <Button
            android:id="@+id/btnSaveSettings"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="Save Changes"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/button_text_color"
            android:background="@drawable/button_gradient"
            app:backgroundTint="@null"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>