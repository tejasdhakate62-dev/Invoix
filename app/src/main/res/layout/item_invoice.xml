<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/card_background"
    android:padding="16dp"
    android:layout_marginBottom="12dp"
    android:gravity="center_vertical">

    <!-- Left side details -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvInvoiceNum"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="#INV-001"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/tvClientName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Client Name"
            android:textSize="13sp"
            android:textColor="#A099C0"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/tvDueDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Due: 2026-07-15"
            android:textSize="11sp"
            android:textColor="#A099C0"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Right side metrics and actions -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <TextView
            android:id="@+id/tvTotalAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$0.00"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <!-- Status badge -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pending"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#FF3366"
            android:layout_marginTop="4dp"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:background="@drawable/edit_text_background" />

        <!-- Toggle Payment Status Action Button -->
        <TextView
            android:id="@+id/tvToggleStatusAction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mark as Paid"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#00FF87"
            android:layout_marginTop="6dp"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true"
            tools:ignore="SmallSp" />
    </LinearLayout>

</LinearLayout>
